{
  "type": "think-admin-plugin",
  "name": "zoujingli/think-plugs-wechat-service",
  "homepage": "https://thinkadmin.top",
  "description": "Wechat Service Plugin for ThinkAdmin",
  "authors": [
    {
      "name": "Anyon",
      "email": "zoujingli@qq.com"
    }
  ],
  "minimum-stability": "dev",
  "require": {
    "php": ">=7.1",
    "ext-json": "*",
    "ext-openssl": "*",
    "ext-mbstring": "*",
    "zoujingli/think-library": "^6.1||v6.0.x-dev",
    "zoujingli/think-install": "^1.0||dev-master",
    "zoujingli/weopen-developer": "^1.0||dev-master"
  },
  "autoload": {
    "psr-4": {
      "plugin\\wechat\\service\\": "src"
    }
  },
  "extra": {
    "think": {
      "services": [
        "plugin\\wechat\\service\\RegisterService"
      ]
    },
    "config": {
      "name": "微信开放平台基础服务",
      "cover": "https://static.cdn.cuci.cc/bd/2a2f272511ee7216cdec6cf3843a38.png"
    },
    "plugin": {
      "copy": {
        "stc/database": "database/migrations"
      }
    }
  },
  "config": {
    "allow-plugins": {
      "zoujingli/think-install": true
    }
  }
}
